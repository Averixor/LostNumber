{
  "name": "lostnumber",
  "private": true,
  "devDependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/status-bar": "^7.0.6",
    "@cursor/sdk": "^1.0.12",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "3.5.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check .",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "check": "node ./scripts/check.mjs",
    "verify:static": "node ./scripts/verify-static-assets.mjs",
    "verify:tagline": "node ./scripts/verify-tagline.mjs",
    "verify:android": "node ./scripts/verify-android-release.mjs",
    "test:smoke": "node ./scripts/smoke-tests.mjs",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "release:check": "node ./scripts/release-check.mjs",
    "build": "npm run build:pages",
    "build:flags:release": "node ./scripts/build-flags.mjs release",
    "build:flags:debug-cheats": "node ./scripts/build-flags.mjs debug-cheats",
    "build:pages": "node ./scripts/build-pages.mjs",
    "android:prepare": "node ./scripts/prepare-android.mjs",
    "android:sync": "node ./scripts/prepare-android.mjs",
    "android:sync:debug-cheats": "node ./scripts/prepare-android.mjs --debug-cheats",
    "android:debug:cheats": "node ./scripts/android-debug-cheats.mjs",
    "android:release": "node ./scripts/android-release.mjs",
    "android:bundle": "node ./scripts/android-bundle.mjs",
    "store:prepare": "python3 ./scripts/prepare-play-store-assets.py && python3 ./scripts/generate-android-icons.py",
    "android:open": "node ./node_modules/@capacitor/cli/bin/capacitor open android",
    "android:run": "node ./scripts/prepare-android.mjs && node ./node_modules/@capacitor/cli/bin/capacitor run android",
    "cursor:audit": "node ./scripts/cursor-audit-local.mjs",
    "cursor:audit:stream": "node ./scripts/cursor-audit-local.mjs --stream"
  }
}
