{
  "name": "lostnumber",
  "version": "2.1.6",
  "private": true,
  "devDependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/status-bar": "^7.0.6",
    "@cursor/sdk": "^1.0.12",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "3.5.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "all": "npm run all:release",
    "all:quick": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "all:checks": "npm run format:check && npm run lint && npm run typecheck && npm run check && npm run verify:static && npm run verify:tagline && npm run test && npm run verify:android && npm run release:check",
    "all:fix": "npm run format && npm run lint:fix",
    "all:godot": "npm run godot:import && npm run godot:test:all",
    "all:android": "npm run store:prepare && npm run android:bundle",
    "all:apk": "npm run android:release",
    "all:release": "npm run android:prepare && npm run all:checks && npm run all:android && npm run pack:unified",
    "all:full": "npm run android:prepare && npm run all:checks && npm run all:godot && npm run all:android && npm run pack:unified",
    "all:deploy": "npm run all:release",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check .",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "check": "node ./scripts/check.mjs",
    "verify:static": "node ./scripts/verify-static-assets.mjs",
    "verify:tagline": "node ./scripts/verify-tagline.mjs",
    "verify:android": "node ./scripts/verify-android-release.mjs",
    "test": "node ./scripts/smoke-tests.mjs",
    "test:smoke": "node ./scripts/smoke-tests.mjs",
    "test:android-assets": "node ./scripts/test-android-assets.mjs",
    "release:check": "node ./scripts/release-check.mjs",
    "release:ideal": "node ./scripts/release-ideal.mjs",
    "build": "npm run build:pages",
    "build:flags:release": "node ./scripts/build-flags.mjs release",
    "build:flags:debug-cheats": "node ./scripts/build-flags.mjs debug-cheats",
    "build:pages": "node ./scripts/build-pages.mjs",
    "privacy:package": "node ./scripts/package-privacy-host.mjs",
    "android:prepare": "node ./scripts/prepare-android.mjs",
    "android:sync": "node ./scripts/prepare-android.mjs",
    "android:sync:debug-cheats": "node ./scripts/prepare-android.mjs --debug-cheats",
    "android:debug:cheats": "node ./scripts/android-debug-cheats.mjs",
    "android:release": "node ./scripts/android-release.mjs",
    "android:bundle": "node ./scripts/android-bundle.mjs",
    "android:open": "node ./node_modules/@capacitor/cli/bin/capacitor open android",
    "android:run": "node ./scripts/prepare-android.mjs && node ./node_modules/@capacitor/cli/bin/capacitor run android",
    "keystore:info": "node ./scripts/keystore-info.mjs",
    "store:prepare": "python3 ./scripts/prepare-play-store-assets.py && python3 ./scripts/generate-android-icons.py",
    "godot:import": "godot4 --path godot --import --headless",
    "godot:test": "godot4 --path godot --headless --script res://scripts/tests/run_rules_tests.gd",
    "godot:test:save": "godot4 --path godot --headless --script res://scripts/tests/run_save_tests.gd",
    "godot:test:smoke": "godot4 --path godot --headless --script res://scripts/tests/run_smoke_tests.gd",
    "godot:test:levels": "godot4 --path godot --headless --script res://scripts/tests/run_level_manager_tests.gd",
    "godot:test:all": "npm run godot:test && npm run godot:test:levels && npm run godot:test:save && npm run godot:test:smoke && npm run godot:test:i18n",
    "godot:test:i18n": "godot4 --path godot --headless --script res://scripts/tests/run_i18n_tests.gd",
    "godot:verify:aab": "bash ./scripts/verify-godot-aab.sh",
    "godot:android:debug": "bash ./scripts/godot-android-export.sh debug",
    "godot:android:install": "bash ./scripts/godot-android-install.sh",
    "godot:android:log": "bash ./scripts/godot-android-logcat.sh",
    "godot:android:pull-debug-log": "bash ./scripts/godot-android-pull-debug-log.sh",
    "godot:android:release": "bash ./scripts/godot-android-export.sh release",
    "pack:unified": "bash ./scripts/pack-unified.sh",
    "cursor:audit": "node ./scripts/cursor-audit-local.mjs",
    "cursor:audit:stream": "node ./scripts/cursor-audit-local.mjs --stream"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
