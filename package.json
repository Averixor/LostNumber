{
  "name": "lostnumber",
  "version": "2.1.6",
  "private": true,
  "devDependencies": {
    "@cursor/sdk": "^1.0.12",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "3.5.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "all": "npm run all:release",
    "all:quick": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "all:checks": "npm run format:check && npm run lint && npm run typecheck && npm run check && npm run verify:tagline && npm run test && npm run release:check",
    "all:fix": "npm run format && npm run lint:fix",
    "all:godot": "npm run godot:import && npm run godot:test:all",
    "all:android": "npm run store:prepare && npm run godot:android:release",
    "all:apk": "npm run godot:android:debug",
    "all:release": "npm run all:checks && npm run all:android && npm run pack:unified",
    "all:full": "npm run all:checks && npm run all:godot && npm run all:android && npm run pack:unified",
    "all:deploy": "npm run all:release",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check .",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "check": "node ./scripts/check.mjs",
    "verify:tagline": "node ./scripts/verify-tagline.mjs",
    "test": "node ./scripts/smoke-tests.mjs",
    "test:smoke": "node ./scripts/smoke-tests.mjs",
    "release:check": "node ./scripts/release-check.mjs",
    "release:ideal": "node ./scripts/release-ideal.mjs",
    "privacy:package": "node ./scripts/package-privacy-host.mjs",
    "keystore:info": "node ./scripts/keystore-info.mjs",
    "store:prepare": "python3 ./scripts/prepare-play-store-assets.py && python3 ./scripts/generate-android-icons.py",
    "godot:import": "bash ./scripts/run-godot-isolated.sh godot4 --path godot --import --headless",
    "godot:test": "bash ./scripts/run-godot-isolated.sh godot4 --path godot --headless --script res://scripts/tests/run_rules_tests.gd",
    "godot:test:save": "bash ./scripts/run-godot-isolated.sh godot4 --path godot --headless --script res://scripts/tests/run_save_tests.gd",
    "godot:test:smoke": "bash ./scripts/run-godot-isolated.sh godot4 --path godot --headless --script res://scripts/tests/run_smoke_tests.gd",
    "godot:test:levels": "bash ./scripts/run-godot-isolated.sh godot4 --path godot --headless --script res://scripts/tests/run_level_manager_tests.gd",
    "godot:test:visual": "bash ./scripts/run-godot-isolated.sh godot4 --path godot --headless --script res://scripts/tests/run_visual_skin_tests.gd",
    "godot:test:perf": "timeout 60s bash ./scripts/run-godot-isolated.sh godot4 --path godot --resolution 420x920 --audio-driver Dummy --script res://scripts/tests/run_long_chain_perf_tests.gd -- \"$PWD/build/qa/godot-long-chain-perf.json\"",
    "godot:test:all": "npm run godot:import && npm run godot:test && npm run godot:test:levels && npm run godot:test:save && npm run godot:test:smoke && npm run godot:test:i18n && npm run godot:test:visual",
    "godot:test:i18n": "bash ./scripts/run-godot-isolated.sh godot4 --path godot --headless --script res://scripts/tests/run_i18n_tests.gd",
    "godot:verify:aab": "bash ./scripts/verify-godot-aab.sh",
    "godot:android:debug": "bash ./scripts/godot-android-export.sh debug",
    "godot:android:install": "bash ./scripts/godot-android-install.sh",
    "godot:android:log": "bash ./scripts/godot-android-logcat.sh",
    "godot:android:pull-debug-log": "bash ./scripts/godot-android-pull-debug-log.sh",
    "godot:android:release": "bash ./scripts/godot-android-export.sh release",
    "pack:unified": "bash ./scripts/pack-unified.sh",
    "cursor:audit": "node ./scripts/cursor-audit-local.mjs",
    "cursor:audit:stream": "node ./scripts/cursor-audit-local.mjs --stream",
    "godot:android:adb-install": "bash ./scripts/godot-android-adb-install.sh"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
