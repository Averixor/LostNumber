# npm на Windows за замовчуванням викликає cmd.exe для lifecycle-scripts.
# Якщо cmd заблоковано — npm використовує цей shell замість cmd:
script-shell=C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe
# Якщо встановлено PowerShell 7 і хочете саме його — замініть рядок вище на:
# script-shell=C:\\Program Files\\PowerShell\\7\\pwsh.exe
