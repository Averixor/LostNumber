extends Node

var BG := Color.html("#070014")
var BG_2 := Color.html("#0d061c")
var PANEL := Color.html("#13071f")
var PANEL_SOFT := Color.html("#1b0b2d")
var MAGENTA := Color.html("#f04cff")
var VIOLET := Color.html("#8d4dff")
var GREEN := Color.html("#62ff39")
var GREEN_DARK := Color.html("#0f3b14")
var GOLD := Color.html("#ffb22e")
var RED := Color.html("#ff3868")
var TEXT := Color.html("#f9eaff")
var MUTED := Color.html("#c9a8d8")

var _cooldown := 0.0


func _ready() -> void:
	process_mode = Node.PROCESS_MODE_ALWAYS
	if get_tree() != null and not get_tree().node_added.is_connected(_on_node_added):
		get_tree().node_added.connect(_on_node_added)
	call_deferred("_style_tree")


func _process(delta: float) -> void:
	_cooldown -= delta
	if _cooldown <= 0.0:
		_cooldown = 0.65
		_style_tree()


func _on_node_added(node: Node) -> void:
	if node is Control:
		call_deferred("_style_one", node)


func _style_tree() -> void:
	var root := get_tree().root
	if root == null:
		return
	_walk(root)


func _walk(node: Node) -> void:
	_style_one(node)
	for child in node.get_children():
		_walk(child)


func _box(bg: Color, border: Color, border_width: int = 2, radius: int = 4, glow: Color = Color.TRANSPARENT, glow_size: int = 0) -> StyleBoxFlat:
	var s := StyleBoxFlat.new()
	s.bg_color = bg
	s.border_color = border
	s.set_border_width_all(border_width)
	s.corner_radius_top_left = radius
	s.corner_radius_top_right = radius
	s.corner_radius_bottom_left = radius
	s.corner_radius_bottom_right = radius
	s.shadow_color = glow
	s.shadow_size = glow_size
	s.content_margin_left = 12
	s.content_margin_right = 12
	s.content_margin_top = 8
	s.content_margin_bottom = 8
	return s


func _style_one(node: Node) -> void:
	if not (node is Control):
		return

	var c := node as Control

	if c is Label:
		var label := c as Label
		label.add_theme_color_override("font_color", TEXT)
		label.add_theme_color_override("font_shadow_color", Color.html("#4d0060"))
		label.add_theme_constant_override("shadow_offset_x", 1)
		label.add_theme_constant_override("shadow_offset_y", 1)

	if c is PanelContainer or c is Panel:
		c.add_theme_stylebox_override("panel", _box(Color.html("#12051fbb"), Color.html("#a735c8aa"), 2, 5, Color.html("#7d21aa66"), 8))

	if c is Button:
		_style_button(c as Button)

	if c is ProgressBar:
		var pb := c as ProgressBar
		pb.add_theme_stylebox_override("background", _box(Color.html("#05020cdd"), Color.html("#23102e"), 1, 3))
		pb.add_theme_stylebox_override("fill", _box(Color.html("#48ff32"), GREEN, 1, 3, GREEN, 8))
		pb.add_theme_color_override("font_color", TEXT)

	if c is LineEdit:
		var le := c as LineEdit
		le.add_theme_stylebox_override("normal", _box(PANEL, MAGENTA, 2, 3, MAGENTA, 6))
		le.add_theme_stylebox_override("focus", _box(PANEL_SOFT, GREEN, 2, 3, GREEN, 8))
		le.add_theme_color_override("font_color", TEXT)

	if c is TextEdit:
		var te := c as TextEdit
		te.add_theme_stylebox_override("normal", _box(PANEL, MAGENTA, 2, 3, MAGENTA, 6))
		te.add_theme_stylebox_override("focus", _box(PANEL_SOFT, GREEN, 2, 3, GREEN, 8))
		te.add_theme_color_override("font_color", TEXT)


func _style_button(button: Button) -> void:
	var txt := button.text.to_lower()
	var accent := MAGENTA
	var bg := Color.html("#1a082bdd")
	var hover_bg := Color.html("#281040ee")
	var pressed_bg := Color.html("#350c4eee")

	if txt.find("продовж") != -1 or txt.find("continue") != -1:
		accent = GREEN
		bg = Color.html("#061b0bdd")
		hover_bg = Color.html("#0b2d13ee")
		pressed_bg = Color.html("#10491cee")
	elif txt.find("нова") != -1 or txt.find("new") != -1:
		accent = MAGENTA
	elif txt.find("назад") != -1 or txt.find("back") != -1:
		accent = VIOLET
	elif txt.find("бомб") != -1 or txt.find("вибух") != -1:
		accent = RED
	elif txt.find("100") != -1 or txt.find("xp") != -1:
		accent = GOLD

	button.add_theme_stylebox_override("normal", _box(bg, accent, 2, 3, accent, 7))
	button.add_theme_stylebox_override("hover", _box(hover_bg, accent.lightened(0.18), 2, 3, accent, 12))
	button.add_theme_stylebox_override("pressed", _box(pressed_bg, accent.lightened(0.25), 2, 3, accent, 14))
	button.add_theme_stylebox_override("focus", _box(bg, GREEN, 2, 3, GREEN, 10))
	button.add_theme_stylebox_override("disabled", _box(Color.html("#11081888"), Color.html("#57345f88"), 1, 3))
	button.add_theme_color_override("font_color", TEXT)
	button.add_theme_color_override("font_hover_color", Color.WHITE)
	button.add_theme_color_override("font_pressed_color", Color.WHITE)
	button.add_theme_color_override("font_disabled_color", Color.html("#8d7894"))
	button.add_theme_font_size_override("font_size", max(15, button.get_theme_font_size("font_size")))

	if button.custom_minimum_size.y < 42.0:
		button.custom_minimum_size.y = 42.0
